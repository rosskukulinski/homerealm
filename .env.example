# homerealm configuration — copy to .env and edit.

# Host path where worlds live (created by setup.sh)
HOST_DATA_DIR=/volume1/docker/homerealm

# Owner for world files. On Synology run `id <your-user>` — use uid=/gid= values.
PUID=1000
PGID=100

# Panel web port
PANEL_PORT=8090

# First world's UDP port; each new world takes the next one up
BASE_PORT=19132

# Shown in the panel as the "away" connect address (Tailscale name, DDNS, or LAN IP)
REMOTE_ADDRESS=

# --- Optional: LAN auto-discovery (worlds appear under "LAN Games") ---
# Requires a docker macvlan network and a handful of static IPs on your LAN
# that are OUTSIDE your DHCP pool. See README before enabling.
DISCOVERY_ENABLED=false
MACVLAN_NETWORK=mcnet
WORLD_IP_PREFIX=192.168.1.
WORLD_IP_FIRST=250
WORLD_IP_LAST=254
